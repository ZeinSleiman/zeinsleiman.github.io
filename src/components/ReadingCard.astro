---
import type { ReadingItem } from "../data/readings";

interface Props {
  reading: ReadingItem;
}

const { reading } = Astro.props;

const statusLabel: Record<string, string> = {
  read: "✅ Read",
  onhold: "⏸️ On Hold",
  future: "📋 To Read",
};

const statusColor: Record<string, string> = {
  read: "bg-green-100 text-green-800",
  onhold: "bg-yellow-100 text-yellow-800",
  future: "bg-blue-100 text-blue-800",
};
---

<article class="border border-gray-200 rounded-lg p-5 mb-4">
  <div class="flex justify-between items-start gap-4">
    <div>
      <h3 class="font-heading text-lg font-bold">
        {reading.bookLink ? (
          <a href={reading.bookLink} target="_blank" rel="noopener" class="hover:text-accent transition-colors">
            {reading.title}
          </a>
        ) : (
          reading.title
        )}
      </h3>
      {reading.subtitle && <p class="text-sm text-gray-500 mt-0.5">{reading.subtitle}</p>}
      <p class="text-sm text-gray-600 mt-1">by {reading.author}</p>
    </div>
    <span class={`text-xs px-2 py-1 rounded-full whitespace-nowrap ${statusColor[reading.status]}`}>
      {statusLabel[reading.status]}
    </span>
  </div>
  {reading.year && <p class="text-xs text-gray-400 mt-2">Read in {reading.year}</p>}
</article>
