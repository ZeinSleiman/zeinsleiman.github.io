---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  date: Date;
  tags: string[];
  description?: string;
}

const { title, date, tags, description } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={title} description={description}>
  <article>
    <h1 class="font-heading text-3xl lg:text-4xl font-bold mb-2">{title}</h1>
    <p class="text-muted text-sm lg:text-base tracking-wide flex items-center gap-4 flex-wrap">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {tags.length > 0 && (
        <span class="flex gap-1.5 flex-wrap">
          {tags.map((tag) => (
            <span class="bg-sidebar text-white px-2 py-0.5 rounded text-xs">{tag}</span>
          ))}
        </span>
      )}
    </p>
    <hr class="my-4 border-gray-200" />
    <div class="prose max-w-none text-base lg:text-lg leading-relaxed space-y-4">
      <slot />
    </div>
  </article>
</BaseLayout>
