---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => data.published !== false))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog">
  <h1 class="font-heading text-3xl lg:text-4xl font-bold mb-4">Welcome</h1>
  <p class="mb-6 text-gray-700 text-base lg:text-lg">
    This is the personal blog of Zein Sleiman — a Software Engineer based in
    Vancouver, British Columbia.
  </p>

  {posts.length > 0 ? (
    posts.map((post) => (
      <article class="my-6 pb-6 border-b border-gray-200">
        <h2 class="font-heading text-xl lg:text-2xl mb-1">
          <a href={`/blog/${post.id.replace(/\.md$/, "")}/`} class="hover:text-accent transition-colors">{post.data.title}</a>
        </h2>
        <p class="text-muted text-sm tracking-wide">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        </p>
        {post.data.description && <p class="mt-2 text-gray-700">{post.data.description}</p>}
      </article>
    ))
  ) : (
    <p class="text-gray-400 italic py-8">No posts available yet.</p>
  )}
</BaseLayout>
